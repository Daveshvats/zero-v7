################################
# SECRETS & CREDENTIALS
# Copy this file to .env and fill in actual values
################################

# PostgreSQL Database (Primary Storage) - Auto-provided by Replit
DATABASE_URL=postgresql://user:password@host:5432/katsumi

# Redis (Upstash) - Get from https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# MongoDB (Contacts & Group Metadata) - Get from https://mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# ItsRose API (Media Processing) - Get from https://itsrose.net
SR_ITSROSE_API_KEY=sk_your_api_key_here
SR_ITSROSE_API_URL=https://api.itsrose.net

################################
# BOT CONFIGURATION
################################

# Session Management
BOT_SESSION_NAME=sessions
BOT_PREFIXES=!,.,/,=

# Owner & Permissions (Array of phone numbers)
OWNER_JIDS=["917404854406","523314539029"]

# Login Method (QR Code or Pairing Code)
QR=true
BOT_NUMBER=62xx

# Experimental Features
BOT_ALLOW_EXPERIMENTAL=false

################################
# DATABASE CONFIGURATION
################################

# MongoDB Store Configuration (for session data)
USE_MONGO=true
USE_MONGO_AUTH=true
MONGO_AUTH_COLLECTION=auth
MONGO_CLONE_DB=clonesessions
MONGO_CLONE_COLLECTION=clonesessions

# Authentication Store (postgres, mongodb, or local)
AUTH_STORE=false
LOCAL_AUTH_PATH=auth_info_baileys
DATABASE_LOCAL_PATH=./sessions/database.json

# MySQL Configuration (Legacy - Optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=baileys
MYSQL_TABLE_NAME=auth

################################
# BOT FEATURES
################################

# Sticker Configuration
packname=⛓️Zero⛓️

# Environment
NODE_ENV=production
LOG_LEVEL=INFO
LOG_TO_FILE=true
